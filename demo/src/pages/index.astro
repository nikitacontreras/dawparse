---
import '../styles/global.css';
import pkg from '../../package.json';
const version = pkg.version;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>dawparse - Open FLP & ZIP Projects Online</title>
    <meta name="description" content="Parse, explore, and preview FL Studio projects (.flp) and Zipped Loop Packages (.zip) entirely in your browser online. No installation required." />
    <meta name="keywords" content="flp online, open fl studio project online, daw parser, zip loop package viewer, flp to midi, fl studio browser" />
    <link rel="canonical" href="https://dawparse.nikitastrike.co/" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dawparse.nikitastrike.co/" />
    <meta property="og:title" content="dawparse - Open FLP & ZIP Projects Online" />
    <meta property="og:description" content="Parse, explore, and preview FL Studio projects and Zipped Loop Packages entirely in your browser." />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://dawparse.nikitastrike.co/" />
    <meta property="twitter:title" content="dawparse - Open FLP & ZIP Projects Online" />
    <meta property="twitter:description" content="Parse, explore, and preview FL Studio projects and Zipped Loop Packages entirely in your browser." />
  </head>
  <body class="bg-neutral-50 text-neutral-800 font-sans min-h-screen">
    <!-- Header -->
    <header class="border-b border-neutral-200 bg-white">
      <div class="max-w-6xl mx-auto px-4 py-5 flex items-center justify-between">
        <div>
          <h1 class="text-xl font-semibold tracking-tight text-neutral-900">dawparse</h1>
          <p class="text-xs text-neutral-500">DAW Project Parsing Library Showcase</p>
        </div>
        <div class="flex items-center space-x-4">
          <a
            href="https://github.com/nikitacontreras/dawparse"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral-600 hover:text-neutral-900 transition-colors flex items-center space-x-1"
            title="GitHub Repository"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.167 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.164 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
            <span class="text-sm font-medium">GitHub</span>
          </a>
          <a
            href="https://www.npmjs.com/package/dawparse"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral-600 hover:text-neutral-900 transition-colors flex items-center space-x-1"
            title="npm Package"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="w-5 h-5 rounded-sm"><path d="M0 0h256v256H0z" fill="#CB3837"/><path d="M48 48h160v160h-32V80h-48v128H48z" fill="#FFF"/></svg>
            <span class="text-sm font-medium">npm</span>
          </a>
          <span class="text-neutral-300">|</span>
          <span class="text-xs bg-neutral-100 border border-neutral-200 text-neutral-600 px-2 py-0.5 rounded-full font-mono">
            v{version}
          </span>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-8">
      <!-- Welcome Description -->
      <section class="mb-8 max-w-2xl">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900 mb-2">DAW Project & Assets Parser Showcase</h2>
        <p class="text-neutral-600 text-sm leading-relaxed">
          Upload any DAW project file (like <code class="font-mono text-xs bg-neutral-100 text-neutral-700 px-1 rounded">.flp</code>)
          or compressed asset package (like <code class="font-mono text-xs bg-neutral-100 text-neutral-700 px-1 rounded">.zip</code>). The file will be decompressed
          and parsed <strong>entirely in your browser</strong> using our type-safe library.
        </p>
      </section>

      <!-- Upload Zone -->
      <section class="mb-8">
        <div
          id="dropzone"
          class="border-2 border-dashed border-neutral-300 rounded-lg p-10 bg-white text-center cursor-pointer hover:border-neutral-400 transition-colors focus-within:outline-none focus-within:ring-2 focus-within:ring-neutral-500"
        >
          <input
            type="file"
            id="file-input"
            class="sr-only"
            accept=".flp,.zip"
          />
          <div class="flex flex-col items-center justify-center space-y-3">
            <!-- Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-neutral-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
            </svg>
            <div class="text-sm font-medium text-neutral-700">
              Drag & drop your file here, or <span class="text-neutral-900 underline underline-offset-2 hover:text-black">browse files</span>
            </div>
            <p class="text-xs text-neutral-400">Supports .flp (FL Studio Project) or .zip (Zipped Loop Package)</p>
          </div>
        </div>
      </section>

      <!-- Error / Loading Statuses -->
      <div id="status-container" class="mb-8 hidden">
        <!-- Loading -->
        <div id="loading-spinner" class="flex items-center space-x-3 text-neutral-500 py-3 justify-center hidden">
          <svg class="animate-spin h-5 w-5 text-neutral-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="text-sm">Reading and parsing DAW file...</span>
        </div>

        <!-- Error Alert -->
        <div id="error-alert" class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-md text-sm hidden">
          <div class="flex">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3 flex-shrink-0 text-red-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
            <div>
              <h3 class="font-semibold mb-1">Failed to parse project file</h3>
              <p id="error-message" class="text-red-600 font-mono text-xs"></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Dashboard Container -->
      <div id="dashboard" class="space-y-8 hidden">
        <!-- Overview Cards -->
        <section class="grid grid-cols-2 sm:grid-cols-5 gap-4">
          <div class="bg-white p-4 border border-neutral-200 rounded-lg shadow-sm">
            <span class="text-xs text-neutral-400 uppercase font-semibold">File Type</span>
            <div id="meta-file-type" class="text-lg font-bold text-neutral-900 mt-1">-</div>
          </div>
          <div class="bg-white p-4 border border-neutral-200 rounded-lg shadow-sm">
            <span class="text-xs text-neutral-400 uppercase font-semibold">Project Tempo</span>
            <div id="meta-bpm" class="text-lg font-bold text-neutral-900 mt-1">-</div>
          </div>
          <div class="bg-white p-4 border border-neutral-200 rounded-lg shadow-sm">
            <span class="text-xs text-neutral-400 uppercase font-semibold">Channel Count</span>
            <div id="meta-channels" class="text-lg font-bold text-neutral-900 mt-1">-</div>
          </div>
          <div class="bg-white p-4 border border-neutral-200 rounded-lg shadow-sm">
            <span class="text-xs text-neutral-400 uppercase font-semibold">Time Division (PPQ)</span>
            <div id="meta-ppq" class="text-lg font-bold text-neutral-900 mt-1">-</div>
          </div>
          <div class="bg-white p-4 border border-neutral-200 rounded-lg shadow-sm">
            <span class="text-xs text-neutral-400 uppercase font-semibold">Parsed Events</span>
            <div id="meta-events-count" class="text-lg font-bold text-neutral-900 mt-1">-</div>
          </div>
        </section>

        <!-- Navigation Tabs -->
        <section class="border-b border-neutral-200">
          <nav class="flex space-x-8" aria-label="Tabs">
            <button
              data-tab="overview"
              class="tab-btn border-b-2 border-neutral-900 py-3 px-1 text-sm font-medium text-neutral-900 focus:outline-none transition-colors"
            >
              Overview & Package Files
            </button>
            <button
              data-tab="channels"
              class="tab-btn border-b-2 border-transparent py-3 px-1 text-sm font-medium text-neutral-500 hover:text-neutral-700 hover:border-neutral-300 focus:outline-none transition-colors"
            >
              Audio Channels
            </button>
            <button
              data-tab="tracks"
              class="tab-btn border-b-2 border-transparent py-3 px-1 text-sm font-medium text-neutral-500 hover:text-neutral-700 hover:border-neutral-300 focus:outline-none transition-colors"
            >
              Tracks Setup
            </button>
            <button
              data-tab="notes"
              class="tab-btn border-b-2 border-transparent py-3 px-1 text-sm font-medium text-neutral-500 hover:text-neutral-700 hover:border-neutral-300 focus:outline-none transition-colors"
            >
              Pattern Notes
            </button>
            <button
              data-tab="events"
              class="tab-btn border-b-2 border-transparent py-3 px-1 text-sm font-medium text-neutral-500 hover:text-neutral-700 hover:border-neutral-300 focus:outline-none transition-colors"
            >
              Raw Events Stream
            </button>
          </nav>
        </section>

        <!-- Tab Panels -->
        <section class="bg-white border border-neutral-200 rounded-lg p-6 shadow-sm min-h-[300px]">
          <!-- Panel 1: Overview -->
          <div id="panel-overview" class="tab-panel space-y-6">
            <div>
              <h3 class="text-sm font-bold text-neutral-900 mb-2 uppercase tracking-wide">FLP Project File Details</h3>
              <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-2 text-sm">
                <div class="flex justify-between border-b border-neutral-100 py-1.5">
                  <dt class="text-neutral-500">Target File Name</dt>
                  <dd id="detail-flp-name" class="font-medium text-neutral-900">-</dd>
                </div>
                <div class="flex justify-between border-b border-neutral-100 py-1.5">
                  <dt class="text-neutral-500">Magic Code</dt>
                  <dd id="detail-magic" class="font-mono text-neutral-900 font-medium">-</dd>
                </div>
                <div class="flex justify-between border-b border-neutral-100 py-1.5">
                  <dt class="text-neutral-500">Header Size</dt>
                  <dd id="detail-header-size" class="font-medium text-neutral-900">-</dd>
                </div>
                <div class="flex justify-between border-b border-neutral-100 py-1.5">
                  <dt class="text-neutral-500">Format Mode</dt>
                  <dd id="detail-format" class="font-medium text-neutral-900">-</dd>
                </div>
              </dl>
            </div>

            <!-- Zip Package File Contents -->
            <div id="zip-files-container" class="hidden">
              <h3 class="text-sm font-bold text-neutral-900 mb-3 uppercase tracking-wide">Assets Extracted from ZIP Package</h3>
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                  <thead>
                    <tr class="border-b border-neutral-200">
                      <th class="py-2 font-medium text-neutral-500">Asset File Name</th>
                      <th class="py-2 text-right font-medium text-neutral-500">Size (Bytes)</th>
                    </tr>
                  </thead>
                  <tbody id="zip-files-list">
                    <!-- Dynamic Rows -->
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Referenced Audio Samples -->
            <div id="flp-samples-container" class="hidden">
              <h3 class="text-sm font-bold text-neutral-900 mb-3 uppercase tracking-wide">Audio Samples Referenced in FLP (Channel Sample Paths)</h3>
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                  <thead>
                    <tr class="border-b border-neutral-200">
                      <th class="py-2 font-medium text-neutral-500">Sample Path / Name</th>
                    </tr>
                  </thead>
                  <tbody id="flp-samples-list">
                    <!-- Dynamic Rows -->
                  </tbody>
                </table>
              </div>
            </div>
            
            <div id="raw-flp-only-msg" class="text-sm text-neutral-500 italic">
              Loaded standard raw FLP project (no external assets attached).
            </div>
          </div>

          <!-- Panel: Audio Channels -->
          <div id="panel-channels" class="tab-panel hidden space-y-4">
            <div class="flex justify-between items-center">
              <h3 class="text-sm font-bold text-neutral-900 uppercase tracking-wide">Channel Rack Audio Channels</h3>
              <span id="channels-count-badge" class="text-xs bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded-full border border-neutral-200">0 Channels</span>
            </div>

            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse text-sm">
                <thead>
                  <tr class="border-b border-neutral-200">
                    <th class="py-3 px-4 font-medium text-neutral-500 w-16 text-center">#</th>
                    <th class="py-3 px-4 font-medium text-neutral-500 w-44">Name</th>
                    <th class="py-2 px-4 font-medium text-neutral-500 truncate">Sample File</th>
                    <th class="py-2 px-4 font-medium text-neutral-500 text-center">Active</th>
                    <th class="py-2 px-4 font-medium text-neutral-500 text-right">Volume</th>
                    <th class="py-2 px-4 font-medium text-neutral-500 text-right">Panning</th>
                    <th class="py-2 px-4 font-medium text-neutral-500 text-center">Play</th>
                  </tr>
                </thead>
                <tbody id="channels-list">
                  <!-- Dynamic Rows -->
                </tbody>
              </table>
            </div>
          </div>

          <!-- Panel 2: Tracks -->
          <div id="panel-tracks" class="tab-panel hidden space-y-4">
            <div class="flex justify-between items-center">
              <h3 class="text-sm font-bold text-neutral-900 uppercase tracking-wide">Project Tracks Layout</h3>
              <span id="tracks-count-badge" class="text-xs bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded-full border border-neutral-200">0 Tracks</span>
            </div>
            
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse text-sm">
                <thead>
                  <tr class="border-b border-neutral-200">
                    <th class="py-2 font-medium text-neutral-500">Track #</th>
                    <th class="py-2 font-medium text-neutral-500">Color</th>
                    <th class="py-2 font-medium text-neutral-500">Icon ID</th>
                    <th class="py-2 font-medium text-neutral-500">Height</th>
                    <th class="py-2 font-medium text-neutral-500">Enabled</th>
                    <th class="py-2 font-medium text-neutral-500">Solo</th>
                    <th class="py-2 font-medium text-neutral-500">Locked</th>
                  </tr>
                </thead>
                <tbody id="tracks-list">
                  <!-- Dynamic Rows -->
                </tbody>
              </table>
            </div>
          </div>

          <div id="panel-notes" class="tab-panel hidden space-y-4">
            <div class="flex justify-between items-center">
              <h3 class="text-sm font-bold text-neutral-900 uppercase tracking-wide">Pattern MIDI Notes</h3>
              <span id="notes-count-badge" class="text-xs bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded-full border border-neutral-200 font-mono">0 Notes</span>
            </div>

            <!-- Pattern & Channel Selectors -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!-- Pattern Selector -->
              <div id="pattern-selector-container" class="flex flex-col space-y-2 bg-neutral-50 border border-neutral-200 rounded-lg p-4 hidden">
                <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Select Pattern / MIDI Sequence:</span>
                <div id="pattern-buttons-list" class="flex flex-wrap gap-2">
                  <!-- Dynamically populated buttons -->
                </div>
              </div>

              <!-- Channel Selector -->
              <div id="channel-selector-container" class="flex flex-col space-y-2 bg-neutral-50 border border-neutral-200 rounded-lg p-4 hidden">
                <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Filter by Instrument / Channel:</span>
                <div id="channel-buttons-list" class="flex flex-wrap gap-2">
                  <!-- Dynamically populated buttons -->
                </div>
              </div>
            </div>

            <!-- Pattern MIDI Visualizer -->
            <div id="piano-roll-container" class="border border-neutral-200 rounded-lg overflow-hidden bg-neutral-100 p-4 hidden">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center space-x-2">
                  <span class="text-xs font-semibold text-neutral-500 uppercase tracking-wider">Pattern MIDI Visualizer</span>
                  <button id="btn-play-preview" class="text-[10px] bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-2 py-0.5 rounded flex items-center space-x-1 cursor-pointer transition-colors shadow-sm" title="Play MIDI sequence preview">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3"><path d="M6.3 2.841A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.269l9.324-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" /></svg>
                    <span>Play</span>
                  </button>
                  <button id="btn-pause-preview" class="text-[10px] bg-amber-500 hover:bg-amber-600 text-white font-semibold px-2 py-0.5 rounded flex items-center space-x-1 cursor-pointer transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed" title="Pause/Resume preview" disabled>
                    <svg id="icon-pause" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3"><path d="M5.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75A.75.75 0 007.25 3h-1.5zM12.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75a.75.75 0 00-.75-.75h-1.5z" /></svg>
                    <span id="text-pause">Pause</span>
                  </button>
                  <button id="btn-stop-preview" class="text-[10px] bg-red-600 hover:bg-red-700 text-white font-semibold px-2 py-0.5 rounded flex items-center space-x-1 cursor-pointer transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed" title="Stop MIDI sequence preview" disabled>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3"><path d="M5.25 3A2.25 2.25 0 003 5.25v9.5A2.25 2.25 0 005.25 17h9.5A2.25 2.25 0 0017 14.75v-9.5A2.25 2.25 0 0014.75 3h-9.5z" /></svg>
                    <span>Stop</span>
                  </button>
                  <div class="flex items-center space-x-1 bg-white border border-neutral-200 rounded px-1.5 py-0.5 shadow-sm">
                    <span class="text-[10px] font-semibold text-neutral-400">BPM:</span>
                    <input id="input-preview-bpm" type="number" value="130" min="20" max="400" class="w-12 text-[10px] font-semibold text-neutral-700 focus:outline-none" />
                  </div>
                </div>
                <span id="piano-roll-info" class="text-xs text-neutral-500 font-mono"></span>
              </div>
              <canvas id="piano-roll-canvas" class="w-full bg-white border border-neutral-200 rounded shadow-sm" style="height: 320px;"></canvas>

              <!-- Synthesizer ADSR & Waveform Controls -->
              <div class="mt-4 p-3 bg-white border border-neutral-200 rounded-lg shadow-sm grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Waveform Select -->
                <div class="flex flex-col space-y-1.5">
                  <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-wider">Sound Waveform</span>
                  <div class="flex gap-2">
                    <label class="flex items-center space-x-1.5 cursor-pointer text-xs font-semibold text-neutral-700 bg-neutral-50 hover:bg-neutral-100 border border-neutral-200 px-2 py-1 rounded transition-colors">
                      <input type="radio" name="synth-waveform" value="sine" class="accent-neutral-800" />
                      <span>Sine</span>
                    </label>
                    <label class="flex items-center space-x-1.5 cursor-pointer text-xs font-semibold text-neutral-700 bg-neutral-50 hover:bg-neutral-100 border border-neutral-200 px-2 py-1 rounded transition-colors">
                      <input type="radio" name="synth-waveform" value="triangle" checked class="accent-neutral-800" />
                      <span>Triangle</span>
                    </label>
                    <label class="flex items-center space-x-1.5 cursor-pointer text-xs font-semibold text-neutral-700 bg-neutral-50 hover:bg-neutral-100 border border-neutral-200 px-2 py-1 rounded transition-colors">
                      <input type="radio" name="synth-waveform" value="sawtooth" class="accent-neutral-800" />
                      <span>Sawtooth</span>
                    </label>
                    <label class="flex items-center space-x-1.5 cursor-pointer text-xs font-semibold text-neutral-700 bg-neutral-50 hover:bg-neutral-100 border border-neutral-200 px-2 py-1 rounded transition-colors">
                      <input type="radio" name="synth-waveform" value="square" class="accent-neutral-800" />
                      <span>Square</span>
                    </label>
                  </div>
                </div>

                <!-- ADSR Envelopes -->
                <div class="grid grid-cols-4 gap-2">
                  <!-- Attack -->
                  <div class="flex flex-col items-center space-y-1">
                    <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-wide">Attack</span>
                    <input id="synth-attack" type="range" min="0" max="1" step="0.01" value="0.05" class="w-full h-1.5 bg-neutral-200 rounded-lg appearance-none cursor-pointer accent-neutral-800" />
                    <span id="label-attack" class="text-[10px] font-mono text-neutral-500">0.05s</span>
                  </div>
                  <!-- Decay -->
                  <div class="flex flex-col items-center space-y-1">
                    <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-wide">Decay</span>
                    <input id="synth-decay" type="range" min="0" max="1" step="0.01" value="0.10" class="w-full h-1.5 bg-neutral-200 rounded-lg appearance-none cursor-pointer accent-neutral-800" />
                    <span id="label-decay" class="text-[10px] font-mono text-neutral-500">0.10s</span>
                  </div>
                  <!-- Sustain -->
                  <div class="flex flex-col items-center space-y-1">
                    <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-wide">Sustain</span>
                    <input id="synth-sustain" type="range" min="0" max="1" step="0.01" value="0.60" class="w-full h-1.5 bg-neutral-200 rounded-lg appearance-none cursor-pointer accent-neutral-800" />
                    <span id="label-sustain" class="text-[10px] font-mono text-neutral-500">60%</span>
                  </div>
                  <!-- Release -->
                  <div class="flex flex-col items-center space-y-1">
                    <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-wide">Release</span>
                    <input id="synth-release" type="range" min="0.01" max="2" step="0.01" value="0.30" class="w-full h-1.5 bg-neutral-200 rounded-lg appearance-none cursor-pointer accent-neutral-800" />
                    <span id="label-release" class="text-[10px] font-mono text-neutral-500">0.30s</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse text-sm">
                <thead>
                  <tr class="border-b border-neutral-200">
                    <th class="py-2 font-medium text-neutral-500">Note Index</th>
                    <th class="py-2 font-medium text-neutral-500">Rack Item</th>
                    <th class="py-2 font-medium text-neutral-500">Sample File</th>
                    <th class="py-2 font-medium text-neutral-500">Position (ticks)</th>
                    <th class="py-2 font-medium text-neutral-500">Duration</th>
                    <th class="py-2 font-medium text-neutral-500">Key Note</th>
                    <th class="py-2 font-medium text-neutral-500">Velocity</th>
                    <th class="py-2 font-medium text-neutral-500">MIDI Channel</th>
                  </tr>
                </thead>
                <tbody id="notes-list">
                  <!-- Dynamic Rows -->
                </tbody>
              </table>
            </div>
          </div>

          <!-- Panel 4: Events -->
          <div id="panel-events" class="tab-panel hidden space-y-4">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="text-sm font-bold text-neutral-900 uppercase tracking-wide">Parsed Events Log</h3>
                <p class="text-xs text-neutral-400 mt-0.5">Showing first 200 events to prevent browser UI lag</p>
              </div>
              <span id="events-count-badge" class="text-xs bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded-full border border-neutral-200 font-mono">0 Events</span>
            </div>

            <div class="overflow-x-auto max-h-[500px] overflow-y-auto border border-neutral-200 rounded-md">
              <table class="w-full text-left border-collapse text-xs font-mono">
                <thead class="sticky top-0 bg-neutral-100 border-b border-neutral-200 shadow-sm z-10">
                  <tr>
                    <th class="py-2 px-3 font-medium text-neutral-500">Idx</th>
                    <th class="py-2 px-3 font-medium text-neutral-500">ID</th>
                    <th class="py-2 px-3 font-medium text-neutral-500">Name</th>
                    <th class="py-2 px-3 font-medium text-neutral-500">Type</th>
                    <th class="py-2 px-3 font-medium text-neutral-500">Parsed Value</th>
                  </tr>
                </thead>
                <tbody id="events-list">
                  <!-- Dynamic Rows -->
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </div>
    </main>

    <!-- Client-Side Scripts -->
    <script>
      import { FLP } from 'dawparse';

      // Element References
      const dropzone = document.getElementById('dropzone')!;
      const fileInput = document.getElementById('file-input') as HTMLInputElement;
      const statusContainer = document.getElementById('status-container')!;
      const loadingSpinner = document.getElementById('loading-spinner')!;
      const errorAlert = document.getElementById('error-alert')!;
      const errorMessage = document.getElementById('error-message')!;
      const dashboard = document.getElementById('dashboard')!;

      // Meta refs
      const metaFileType = document.getElementById('meta-file-type')!;
      const metaBpm = document.getElementById('meta-bpm')!;
      const metaChannels = document.getElementById('meta-channels')!;
      const metaPpq = document.getElementById('meta-ppq')!;
      const metaEventsCount = document.getElementById('meta-events-count')!;

      // Details refs
      const detailFlpName = document.getElementById('detail-flp-name')!;
      const detailMagic = document.getElementById('detail-magic')!;
      const detailHeaderSize = document.getElementById('detail-header-size')!;
      const detailFormat = document.getElementById('detail-format')!;

      // Lists & containers
      const zipFilesContainer = document.getElementById('zip-files-container')!;
      const flpSamplesContainer = document.getElementById('flp-samples-container')!;
      const flpSamplesList = document.getElementById('flp-samples-list')!;
      const rawFlpOnlyMsg = document.getElementById('raw-flp-only-msg')!;
      const zipFilesList = document.getElementById('zip-files-list')!;
      const channelsList = document.getElementById('channels-list')!;
      const channelsCountBadge = document.getElementById('channels-count-badge')!;
      const tracksList = document.getElementById('tracks-list')!;
      const tracksCountBadge = document.getElementById('tracks-count-badge')!;
      const notesList = document.getElementById('notes-list')!;
      const notesCountBadge = document.getElementById('notes-count-badge')!;
      const pianoRollContainer = document.getElementById('piano-roll-container')!;
      const patternSelectorContainer = document.getElementById('pattern-selector-container')!;
      const patternButtonsList = document.getElementById('pattern-buttons-list')!;
      const channelSelectorContainer = document.getElementById('channel-selector-container')!;
      const channelButtonsList = document.getElementById('channel-buttons-list')!;
      const btnPlayPreview = document.getElementById('btn-play-preview') as HTMLButtonElement;
      const btnPausePreview = document.getElementById('btn-pause-preview') as HTMLButtonElement;
      const btnStopPreview = document.getElementById('btn-stop-preview') as HTMLButtonElement;
      const textPause = document.getElementById('text-pause')!;
      const iconPause = document.getElementById('icon-pause')!;
      const eventsList = document.getElementById('events-list')!;
      const eventsCountBadge = document.getElementById('events-count-badge')!;

      // File handling events
      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('border-neutral-900', 'bg-neutral-100');
      });
      dropzone.addEventListener('dragleave', () => {
        dropzone.classList.remove('border-neutral-900', 'bg-neutral-100');
      });
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('border-neutral-900', 'bg-neutral-100');
        if (e.dataTransfer?.files?.length) {
          processFile(e.dataTransfer.files[0]);
        }
      });
      fileInput.addEventListener('change', () => {
        if (fileInput.files?.length) {
          processFile(fileInput.files[0]);
        }
      });

      // ADSR Sliders event listeners
      const adsrInputs = ['attack', 'decay', 'sustain', 'release'];
      adsrInputs.forEach(type => {
        const input = document.getElementById(`synth-${type}`) as HTMLInputElement | null;
        const label = document.getElementById(`label-${type}`) as HTMLSpanElement | null;
        if (input && label) {
          input.addEventListener('input', () => {
            const val = parseFloat(input.value);
            if (type === 'sustain') {
              label.textContent = `${Math.round(val * 100)}%`;
            } else {
              label.textContent = `${val.toFixed(2)}s`;
            }
          });
        }
      });

      // State for notes and PPQ
      let currentNotes: any[] = [];
      let currentPPQ = 96;
      let currentChannels: any[] = [];
      let parsedPatterns: any[] = [];
      let selectedPatternIndex = -1;
      let selectedChannelRackIndex = -1;
      let currentMaxEnd = 0;

      let sampleBuffers: Record<number, AudioBuffer> = {};
      let activeChannelSources: Record<number, AudioBufferSourceNode> = {};

      const PLAY_SVG = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 ml-0.5"><path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd" /></svg>';
      const STOP_SVG = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3"><path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd" /></svg>';

      // Audio Preview State
      let audioCtx: AudioContext | null = null;
      let activeOscillators: OscillatorNode[] = [];
      let activeSampleSources: AudioBufferSourceNode[] = [];
      let isPlaying = false;
      let playStartTime = 0;
      let playAnimationId: number | null = null;

      // Color scheme palette for different Channel Rack channels to color code notes
      const RACK_COLORS = [
        { fill: 'rgba(249, 115, 22, alpha)', stroke: '#ea580c' }, // Orange
        { fill: 'rgba(14, 165, 233, alpha)', stroke: '#0284c7' }, // Sky
        { fill: 'rgba(168, 85, 247, alpha)', stroke: '#9333ea' }, // Purple
        { fill: 'rgba(16, 185, 129, alpha)', stroke: '#059669' }, // Emerald
        { fill: 'rgba(244, 63, 94, alpha)', stroke: '#e11d48' },  // Rose
        { fill: 'rgba(234, 179, 8, alpha)', stroke: '#ca8a04' },  // Yellow/Amber
        { fill: 'rgba(99, 102, 241, alpha)', stroke: '#4f46e5' }, // Indigo
        { fill: 'rgba(20, 184, 166, alpha)', stroke: '#0d9488' }, // Teal
      ];

      // Tabs Logic
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabPanels = document.querySelectorAll('.tab-panel');

      tabBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const tabName = btn.getAttribute('data-tab')!;
          
          tabBtns.forEach((t) => {
            t.classList.remove('border-neutral-900', 'text-neutral-900');
            t.classList.add('border-transparent', 'text-neutral-500');
          });
          btn.classList.add('border-neutral-900', 'text-neutral-900');
          btn.classList.remove('border-transparent', 'text-neutral-500');

          tabPanels.forEach((panel) => {
            if (panel.id === `panel-${tabName}`) {
              panel.classList.remove('hidden');
            } else {
              panel.classList.add('hidden');
            }
          });

          if (tabName === 'notes' && currentNotes.length > 0) {
            requestAnimationFrame(() => {
              const filteredNotes = selectedChannelRackIndex === -1
                ? currentNotes
                : currentNotes.filter((n) => n.rack === selectedChannelRackIndex);
              drawPianoRoll(filteredNotes, currentPPQ);
            });
          } else {
            // Stop preview if playing when switching away
            stopPreview();
          }
        });
      });

      window.addEventListener('resize', () => {
        if (currentNotes.length > 0) {
          const filteredNotes = selectedChannelRackIndex === -1
            ? currentNotes
            : currentNotes.filter((n) => n.rack === selectedChannelRackIndex);
          drawPianoRoll(filteredNotes, currentPPQ);
        }
      });

      // Preview Buttons Event Listeners
      btnPlayPreview.addEventListener('click', playPreview);
      btnStopPreview.addEventListener('click', stopPreview);
      btnPausePreview.addEventListener('click', togglePausePreview);

      // File Processing
      function processFile(file: File) {
        showLoading();

        const reader = new FileReader();
        reader.onload = (event) => {
          try {
            const buffer = new Uint8Array(event.target!.result as ArrayBuffer);
            const isZip = file.name.toLowerCase().endsWith('.zip');
            
            // Instantiate FLP from local dawparse
            const flp = isZip ? new FLP({ zip: buffer }) : new FLP({ file: buffer });

            renderDashboard(flp, file.name, isZip);
          } catch (err: any) {
            showError(err.message || String(err));
          }
        };
        reader.onerror = () => {
          showError('Failed to read uploaded file binary content.');
        };
        reader.readAsArrayBuffer(file);
      }

      function showLoading() {
        statusContainer.classList.remove('hidden');
        loadingSpinner.classList.remove('hidden');
        errorAlert.classList.add('hidden');
        dashboard.classList.add('hidden');
      }

      function showError(msg: string) {
        statusContainer.classList.remove('hidden');
        loadingSpinner.classList.add('hidden');
        errorAlert.classList.remove('hidden');
        errorMessage.textContent = msg;
        dashboard.classList.add('hidden');
      }

      function renderDashboard(flp: any, originalFileName: string, isZip: boolean) {
        statusContainer.classList.add('hidden');
        dashboard.classList.remove('hidden');

        // Cleanup any currently playing audio from previous projects
        stopPreview();
        stopAllChannels();

        // Populate Overview Cards
        metaFileType.textContent = isZip ? 'Zipped Package (.zip)' : 'FLP Project (.flp)';
        metaChannels.textContent = String(flp.project.header.channelCount);
        metaPpq.textContent = String(flp.project.header.ppq);
        metaEventsCount.textContent = String(flp.project.events.length);

        currentPPQ = flp.project.header.ppq;
        sampleBuffers = {}; // reset decoded buffers
        
        // Initialize Audio Context proactively if not already initialized
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        }

        // Populate Details Info
        detailFlpName.textContent = flp.flpName || originalFileName;
        detailMagic.textContent = flp.project.header.magic;
        detailHeaderSize.textContent = `${flp.project.header.headerSize} bytes`;
        detailFormat.textContent = `Mode ${flp.project.header.fmt}`;

        // Populate ZIP Files if available
        zipFilesList.innerHTML = '';
        if (isZip && flp.files) {
          zipFilesContainer.classList.remove('hidden');
          rawFlpOnlyMsg.classList.add('hidden');
          
          Object.entries(flp.files).forEach(([filename, bytes]: [string, any]) => {
            const row = document.createElement('tr');
            row.className = 'border-b border-neutral-100 hover:bg-neutral-50';
            row.innerHTML = `
              <td class="py-2 text-neutral-800 font-medium">${filename}</td>
              <td class="py-2 text-right text-neutral-600 font-mono">${bytes.length.toLocaleString()}</td>
            `;
            zipFilesList.appendChild(row);
          });
        } else {
          zipFilesContainer.classList.add('hidden');
          rawFlpOnlyMsg.classList.remove('hidden');
        }

        // Extract and Render Referenced Audio Samples (Event ID 196)
        flpSamplesList.innerHTML = '';
        const sampleEvents = flp.project.events.filter((e: any) => e.id === 196 && typeof e.value === 'string' && e.value.trim().length > 0);
        
        if (sampleEvents.length > 0) {
          flpSamplesContainer.classList.remove('hidden');
          // Remove duplicates to show unique list of samples
          const uniqueSamples = Array.from(new Set(sampleEvents.map((e: any) => e.value)));
          
          uniqueSamples.forEach((samplePath: any) => {
            const row = document.createElement('tr');
            row.className = 'border-b border-neutral-100 hover:bg-neutral-50';
            row.innerHTML = `
              <td class="py-2 text-neutral-800 font-mono text-xs break-all">${samplePath}</td>
            `;
            flpSamplesList.appendChild(row);
          });
        } else {
          flpSamplesContainer.classList.add('hidden');
        }

        // Extract, Parse and Render Audio Channels
        channelsList.innerHTML = '';
        const channels = parseChannels(flp.project.events);
        currentChannels = channels;
        channelsCountBadge.textContent = `${channels.length} Channels`;

        if (channels.length === 0) {
          channelsList.innerHTML = `
            <tr>
              <td colspan="6" class="py-8 text-center text-neutral-400 italic">No audio channels found.</td>
            </tr>
          `;
        } else {
          channels.forEach((ch: any) => {
            const row = document.createElement('tr');
            row.className = 'border-b border-neutral-100 hover:bg-neutral-50';
            
            const activeIcon = ch.enabled
              ? `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 text-emerald-600" title="Active"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>`
              : `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 text-neutral-300" title="Inactive"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>`;

            const panVal = ch.panning; // -100 to 100
            let panLabel = 'C';
            if (panVal > 0) panLabel = `R${panVal}`;
            if (panVal < 0) panLabel = `L${Math.abs(panVal)}`;

            const dotPosition = Math.max(0, Math.min(100, 50 + (panVal / 2)));
            const panSlider = `
              <div class="flex items-center space-x-2 justify-end">
                <span class="text-xs font-mono text-neutral-500 w-10 text-right">${panLabel}</span>
                <div class="w-16 h-1 bg-neutral-200 rounded-full relative">
                  <span class="absolute w-2 h-2 bg-neutral-800 rounded-full -top-0.5" style="left: calc(${dotPosition}% - 4px)"></span>
                </div>
              </div>
            `;

            const samplePath = ch.samplePath || '';
            let sampleContent = '';
            if (samplePath === 'Generator (No Sample)' || !samplePath) {
              sampleContent = `<span class="text-neutral-400 italic">Generator (No Sample)</span>`;
            } else {
              const filename = samplePath.split('\\').pop()?.split('/').pop() || samplePath;
              sampleContent = `
                <details class="group">
                  <summary class="cursor-pointer list-none flex items-center gap-1.5 hover:text-neutral-900 transition-colors">
                    <svg class="w-3.5 h-3.5 text-neutral-400 group-open:rotate-90 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                    <span class="truncate font-semibold text-neutral-700 max-w-[150px] sm:max-w-[250px] md:max-w-[350px]" title="${filename}">${filename}</span>
                  </summary>
                  <div class="mt-2.5 mb-1 pl-3 pr-2 py-2.5 bg-white border border-neutral-200 rounded-md text-[10px] text-neutral-500 break-all shadow-sm relative">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-neutral-200 rounded-l-md"></div>
                    <strong class="font-semibold text-neutral-800 block mb-1 uppercase tracking-wide">Full Source Path</strong>
                    ${samplePath}
                  </div>
                </details>
              `;
            }

            row.innerHTML = `
              <td class="py-3 px-4 align-top text-center font-semibold text-neutral-500">${ch.index + 1}</td>
              <td class="py-3 px-4 align-top font-semibold text-neutral-900 truncate max-w-[176px]" title="${ch.name}">${ch.name}</td>
              <td class="py-3 px-4 align-top text-neutral-600 font-mono text-xs">
                ${sampleContent}
              </td>
              <td class="py-3 px-4 align-top text-center"><span class="inline-flex justify-center mt-0.5">${activeIcon}</span></td>
              <td class="py-3 px-4 align-top text-right text-neutral-700 font-mono"><span class="mt-0.5 block">${ch.volume}%</span></td>
              <td class="py-3 px-4 align-top text-right"><div class="mt-1.5">${panSlider}</div></td>
              <td class="py-3 px-4 align-top text-center">
                <button class="btn-play-channel w-6 h-6 inline-flex items-center justify-center rounded-full bg-neutral-100 hover:bg-neutral-200 text-neutral-600 transition-colors" data-channel-idx="${ch.index}" title="Play Sample">
                  ${PLAY_SVG}
                </button>
              </td>
            `;
            channelsList.appendChild(row);
          });
          
          // Delegate click events for play buttons
          channelsList.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            const btn = target.closest('.btn-play-channel') as HTMLButtonElement | null;
            if (btn) {
              const idx = parseInt(btn.getAttribute('data-channel-idx') || '-1');
              
              // If already playing, stop it
              if (activeChannelSources[idx]) {
                try {
                  activeChannelSources[idx].stop();
                } catch (e) {}
                delete activeChannelSources[idx];
                btn.innerHTML = PLAY_SVG;
                btn.classList.remove('text-red-500');
                btn.classList.add('text-neutral-600');
                return;
              }

              const buffer = sampleBuffers[idx];
              if (buffer && audioCtx) {
                const source = audioCtx.createBufferSource();
                source.buffer = buffer;
                source.connect(audioCtx.destination);
                
                source.onended = () => {
                  delete activeChannelSources[idx];
                  btn.innerHTML = PLAY_SVG;
                  btn.classList.remove('text-red-500');
                  btn.classList.add('text-neutral-600');
                };

                source.start(0);
                activeChannelSources[idx] = source;
                
                btn.innerHTML = STOP_SVG;
                btn.classList.remove('text-neutral-600');
                btn.classList.add('text-red-500');
              } else {
                alert('No audio sample available for this channel (it might be a Generator or missing file).');
              }
            }
          });
          
          // Decode Audio Samples asynchronously
          if (isZip && flp.files && audioCtx) {
            channels.forEach((ch: any) => {
              // Try to find the exact file name or a file ending with the samplePath
              const sampleName = ch.samplePath;
              if (sampleName && sampleName !== 'Generator (No Sample)') {
                let matchedFileBuffer = null;
                // Direct match
                if (flp.files[sampleName]) {
                  matchedFileBuffer = flp.files[sampleName];
                } else {
                  // Fallback: search for basename
                  const basename = sampleName.split('\\').pop()?.split('/').pop();
                  if (basename) {
                    for (const [fname, bytes] of Object.entries(flp.files)) {
                      if (fname === basename || fname.endsWith(`/${basename}`) || fname.endsWith(`\\${basename}`)) {
                        matchedFileBuffer = bytes;
                        break;
                      }
                    }
                  }
                }
                
                if (matchedFileBuffer) {
                  // Copy Uint8Array into a new ArrayBuffer because decodeAudioData transfers the buffer
                  const arrayBuffer = matchedFileBuffer.buffer.slice(
                    matchedFileBuffer.byteOffset,
                    matchedFileBuffer.byteOffset + matchedFileBuffer.byteLength
                  );
                  audioCtx!.decodeAudioData(arrayBuffer, (decodedData) => {
                    sampleBuffers[ch.index] = decodedData;
                  }).catch(e => console.warn('Failed to decode audio for channel', ch.index, e));
                }
              }
            });
          }
        }

        // Extract and Render Tracks
        tracksList.innerHTML = '';
        const trackEvents = flp.project.events.filter((e: any) => e.id === 238);
        tracksCountBadge.textContent = `${trackEvents.length} Tracks`;

        if (trackEvents.length === 0) {
          tracksList.innerHTML = `
            <tr>
              <td colspan="7" class="py-8 text-center text-neutral-400 italic">No track layout information found.</td>
            </tr>
          `;
        } else {
          trackEvents.forEach((evt: any) => {
            const track = evt.value;
            const row = document.createElement('tr');
            row.className = 'border-b border-neutral-100 hover:bg-neutral-50';
            
            const colorRgb = `rgb(${track.color.red}, ${track.color.green}, ${track.color.blue})`;
            const colorHex = '#' + [track.color.red, track.color.green, track.color.blue]
              .map(x => x.toString(16).padStart(2, '0')).join('').toUpperCase();

            row.innerHTML = `
              <td class="py-3 font-semibold text-neutral-900">Track ${track.idx + 1}</td>
              <td class="py-3 flex items-center space-x-2">
                <span class="w-4 h-4 rounded" style="background-color: ${colorRgb}"></span>
                <span class="text-xs font-mono text-neutral-500">${colorHex}</span>
              </td>
              <td class="py-3 text-neutral-600 font-mono">${track.icon === -1 ? 'None' : track.icon}</td>
              <td class="py-3 text-neutral-600">${track.height.toFixed(1)}</td>
              <td class="py-3">${renderBadge(track.enabled, 'Yes', 'No')}</td>
              <td class="py-3">${renderBadge(track.solo, 'Yes', 'No')}</td>
              <td class="py-3">${renderBadge(track.locked, 'Yes', 'No')}</td>
            `;
            tracksList.appendChild(row);
          });
        }

        // Determine BPM cleanly from the FLP class bpm getter
        const defaultBpm = flp.bpm;
        metaBpm.textContent = `${defaultBpm} BPM`;

        const bpmInput = document.getElementById('input-preview-bpm') as HTMLInputElement | null;
        if (bpmInput) {
          bpmInput.value = String(defaultBpm);
        }

        // Extract, Parse and Render MIDI Notes grouped by Pattern
        parsedPatterns = parsePatterns(flp.project.events);

        if (parsedPatterns.length === 0) {
          patternSelectorContainer.classList.add('hidden');
          pianoRollContainer.classList.add('hidden');
          notesCountBadge.textContent = '0 Notes';
          notesList.innerHTML = `
            <tr>
              <td colspan="7" class="py-8 text-center text-neutral-400 italic">No pattern MIDI notes found.</td>
            </tr>
          `;
        } else {
          patternSelectorContainer.classList.remove('hidden');
          
          // Select first pattern by default
          selectedPatternIndex = parsedPatterns[0].index;
          selectedChannelRackIndex = -1;
          renderPatternSelectorButtons();
          renderActivePattern(parsedPatterns[0]);
        }

        // Render Raw Events
        eventsList.innerHTML = '';
        eventsCountBadge.textContent = `${flp.project.events.length} Events`;
        
        flp.project.events.slice(0, 200).forEach((evt: any, idx: number) => {
          const row = document.createElement('tr');
          row.className = 'border-b border-neutral-100 hover:bg-neutral-50';
          
          let valStr = '';
          if (typeof evt.value === 'string') {
            valStr = `"${evt.value}"`;
          } else if (evt.value && typeof evt.value === 'object' && !(evt.value instanceof Uint8Array)) {
            valStr = JSON.stringify(evt.value);
          } else if (evt.value instanceof Uint8Array) {
            valStr = `[Binary: ${evt.value.length} bytes]`;
          } else {
            valStr = String(evt.value);
          }

          row.innerHTML = `
            <td class="py-2 px-3 text-neutral-400">${idx}</td>
            <td class="py-2 px-3 font-semibold text-neutral-800">${evt.id}</td>
            <td class="py-2 px-3 text-neutral-900">${evt.name}</td>
            <td class="py-2 px-3"><span class="bg-neutral-100 px-1 py-0.5 rounded text-xs text-neutral-600 font-sans">${evt.type}</span></td>
            <td class="py-2 px-3 text-neutral-600 font-sans truncate max-w-xs" title="${valStr.replace(/"/g, '&quot;')}">${valStr}</td>
          `;
          eventsList.appendChild(row);
        });

        if (flp.project.events.length > 200) {
          const row = document.createElement('tr');
          row.innerHTML = `<td colspan="5" class="py-3 px-3 text-center text-neutral-400 text-xs italic">... and ${flp.project.events.length - 200} more events</td>`;
          eventsList.appendChild(row);
        }
      }

      function renderBadge(status: number | boolean, trueLabel: string, falseLabel: string): string {
        const isActive = !!status;
        const colorClass = isActive 
          ? 'bg-neutral-900 text-white font-medium border border-neutral-900' 
          : 'bg-white text-neutral-400 border border-neutral-200';
        return `<span class="px-2 py-0.5 rounded-full text-xs font-sans ${colorClass}">${isActive ? trueLabel : falseLabel}</span>`;
      }

      // Convert MIDI note key to text name (e.g. 60 -> C5)
      function getNoteName(key: number): string {
        const notes = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B'];
        const octave = Math.floor(key / 12) - 1;
        const noteName = notes[key % 12];
        return `${noteName}${octave}`;
      }

      function drawPianoRoll(notes: any[], ppq: number, playheadTick?: number) {
        const canvas = document.getElementById('piano-roll-canvas') as HTMLCanvasElement | null;
        const info = document.getElementById('piano-roll-info');
        if (!canvas || !info) return;

        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        const rect = canvas.getBoundingClientRect();
        if (rect.width <= 0) return;

        const dpr = window.devicePixelRatio || 1;
        canvas.width = rect.width * dpr;
        canvas.height = 320 * dpr;
        ctx.scale(dpr, dpr);

        const width = rect.width;
        const height = 320;

        ctx.clearRect(0, 0, width, height);

        let minKey = 127;
        let maxKey = 0;
        let maxEnd = 0;

        notes.forEach((n) => {
          if (n.key < minKey) minKey = n.key;
          if (n.key > maxKey) maxKey = n.key;
          const end = n.position + n.duration;
          if (end > maxEnd) maxEnd = end;
        });

        minKey = Math.max(0, minKey - 1);
        maxKey = Math.min(127, maxKey + 1);
        const pitchRange = maxKey - minKey + 1;

        const minDuration = 4 * 4 * ppq;
        if (maxEnd < minDuration) maxEnd = minDuration;
        currentMaxEnd = maxEnd;

        info.textContent = `Pitches: ${getNoteName(minKey)} to ${getNoteName(maxKey)} | Total Duration: ${maxEnd} ticks`;

        const keyboardWidth = 45;
        const gridWidth = width - keyboardWidth;
        const rowHeight = height / pitchRange;

        const blackKeys = [1, 3, 6, 8, 10];

        // 1. Draw Grid Background (alternate black/white keys)
        for (let r = 0; r < pitchRange; r++) {
          const currentKey = maxKey - r;
          const noteIndex = currentKey % 12;
          const isBlack = blackKeys.includes(noteIndex);
          const y = r * rowHeight;

          ctx.fillStyle = isBlack ? '#f5f5f5' : '#ffffff';
          ctx.fillRect(keyboardWidth, y, gridWidth, rowHeight);

          ctx.strokeStyle = '#e5e5e5';
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(keyboardWidth, y + rowHeight);
          ctx.lineTo(width, y + rowHeight);
          ctx.stroke();
        }

        // 2. Draw Vertical Grid Lines (Beats and Bars)
        const ticksPerBeat = ppq;
        const ticksPerBar = ppq * 4;

        for (let t = 0; t <= maxEnd; t += ticksPerBeat) {
          const x = keyboardWidth + (t / maxEnd) * gridWidth;
          const isBar = t % ticksPerBar === 0;

          ctx.strokeStyle = isBar ? '#d4d4d4' : '#f5f5f5';
          ctx.lineWidth = isBar ? 1 : 0.5;

          ctx.beginPath();
          ctx.moveTo(x, 0);
          ctx.lineTo(x, height);
          ctx.stroke();
        }

        // 3. Draw MIDI Notes
        notes.forEach((note) => {
          const x = keyboardWidth + (note.position / maxEnd) * gridWidth;
          const w = (note.duration / maxEnd) * gridWidth;
          const row = maxKey - note.key;
          const y = row * rowHeight + 1.5;
          const h = rowHeight - 3;

          const alpha = 0.5 + (note.velocity / 127) * 0.45;
          const colorScheme = RACK_COLORS[note.rack % RACK_COLORS.length];
          ctx.fillStyle = colorScheme.fill.replace('alpha', String(alpha));
          ctx.strokeStyle = colorScheme.stroke;
          ctx.lineWidth = 1;

          drawRoundedRect(ctx, x, y, Math.max(2, w), Math.max(2, h), 2);
          ctx.fill();
          ctx.stroke();
        });

        // 4. Draw Piano Keyboard on the left
        // Draw base white keyboard background
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, keyboardWidth, height);

        // Draw white key dividers and label C notes
        for (let r = 0; r < pitchRange; r++) {
          const currentKey = maxKey - r;
          const noteIndex = currentKey % 12;
          const isBlack = blackKeys.includes(noteIndex);
          const y = r * rowHeight;

          if (!isBlack) {
            ctx.strokeStyle = '#cbd5e1';
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(0, y + rowHeight);
            ctx.lineTo(keyboardWidth, y + rowHeight);
            ctx.stroke();

            if (noteIndex === 0 && rowHeight > 7) {
              ctx.fillStyle = '#64748b';
              ctx.font = `${Math.min(9, rowHeight - 2)}px monospace`;
              ctx.textBaseline = 'middle';
              ctx.fillText(getNoteName(currentKey), 3, y + rowHeight / 2);
            }
          }
        }

        // Draw black keys on top (partial width to look like a real keyboard)
        for (let r = 0; r < pitchRange; r++) {
          const currentKey = maxKey - r;
          const noteIndex = currentKey % 12;
          const isBlack = blackKeys.includes(noteIndex);
          const y = r * rowHeight;

          if (isBlack) {
            ctx.fillStyle = '#1e293b';
            ctx.fillRect(0, y + 0.5, keyboardWidth * 0.65, rowHeight - 1);

            ctx.strokeStyle = '#0f172a';
            ctx.lineWidth = 0.5;
            ctx.strokeRect(0, y + 0.5, keyboardWidth * 0.65, rowHeight - 1);
          }
        }

        ctx.strokeStyle = '#94a3b8';
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.moveTo(keyboardWidth, 0);
        ctx.lineTo(keyboardWidth, height);
        ctx.stroke();

        // 5. Draw Playhead Line if playing
        if (playheadTick !== undefined) {
          const playheadX = keyboardWidth + (playheadTick / maxEnd) * gridWidth;
          ctx.strokeStyle = '#ef4444'; // Red playhead
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.moveTo(playheadX, 0);
          ctx.lineTo(playheadX, height);
          ctx.stroke();

          // Draw small playhead triangle on top
          ctx.fillStyle = '#ef4444';
          ctx.beginPath();
          ctx.moveTo(playheadX - 4, 0);
          ctx.lineTo(playheadX + 4, 0);
          ctx.lineTo(playheadX, 5);
          ctx.fill();
        }
      }

      function drawRoundedRect(ctx: CanvasRenderingContext2D, x: number, y: number, width: number, height: number, radius: number) {
        ctx.beginPath();
        ctx.moveTo(x + radius, y);
        ctx.lineTo(x + width - radius, y);
        ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
        ctx.lineTo(x + width, y + height - radius);
        ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
        ctx.lineTo(x + radius, y + height);
        ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
        ctx.lineTo(x, y + radius);
        ctx.quadraticCurveTo(x, y, x + radius, y);
        ctx.closePath();
      }

      function parseChannels(events: any[]): any[] {
        const channels: any[] = [];
        let currentChannel: any = null;
        let channelIdx = 0;

        for (const event of events) {
          if (event.id === 64) {
            currentChannel = {
              index: channelIdx++,
              name: `Channel ${channelIdx}`,
              enabled: true,
              volume: 78,
              panning: 0,
              samplePath: 'Generator (No Sample)',
              type: 0,
            };
            channels.push(currentChannel);
          } else if (currentChannel) {
            if (event.id === 0) {
              currentChannel.enabled = event.value === 1;
            } else if (event.id === 2) {
              currentChannel.volume = Math.round((event.value / 127) * 100);
            } else if (event.id === 72) {
              currentChannel.volume = Math.round((event.value / 12800) * 100);
            } else if (event.id === 3) {
              currentChannel.panning = event.value - 64;
            } else if (event.id === 73) {
              currentChannel.panning = Math.round((event.value - 6400) / 64);
            } else if (event.id === 192) {
              currentChannel.name = cleanString(event.value);
            } else if (event.id === 196) {
              currentChannel.samplePath = cleanString(event.value);
            } else if (event.id === 21) {
              currentChannel.type = event.value;
            } else if (event.id === 219) {
              const levels = event.value;
              if (levels && typeof levels === 'object') {
                if (levels.volume !== undefined) {
                  currentChannel.volume = Math.round((levels.volume / 12800) * 100);
                }
                if (levels.pan !== undefined) {
                  currentChannel.panning = Math.round((levels.pan - 6400) / 64);
                }
              }
            }
          }
        }
        return channels;
      }

      function cleanString(str: any): string {
        if (typeof str !== 'string') return '';
        let cleaned = str.replace(/\u0000/g, '');
        return cleaned.trim();
      }

      function parsePatterns(events: any[]): any[] {
        const patterns: Record<number, any> = {};
        let currentPatternIdx = 1;
        patterns[1] = {
          index: 1,
          name: 'Pattern 1',
          notes: [],
        };

        for (const event of events) {
          if (event.id === 65) {
            currentPatternIdx = event.value;
            if (!patterns[currentPatternIdx]) {
              patterns[currentPatternIdx] = {
                index: currentPatternIdx,
                name: `Pattern ${currentPatternIdx}`,
                notes: [],
              };
            }
          } else if (event.id === 193) {
            const name = cleanString(event.value);
            if (name) {
              if (currentPatternIdx !== -1) {
                if (!patterns[currentPatternIdx]) {
                  patterns[currentPatternIdx] = {
                    index: currentPatternIdx,
                    name: name,
                    notes: [],
                  };
                } else {
                  patterns[currentPatternIdx].name = name;
                }
              }
            }
          } else if (event.id === 224 && Array.isArray(event.value)) {
            if (currentPatternIdx !== -1) {
              if (!patterns[currentPatternIdx]) {
                patterns[currentPatternIdx] = {
                  index: currentPatternIdx,
                  name: `Pattern ${currentPatternIdx}`,
                  notes: [],
                };
              }
              patterns[currentPatternIdx].notes = patterns[currentPatternIdx].notes.concat(event.value);
            }
          }
        }

        return Object.values(patterns).filter((p) => p.notes.length > 0);
      }

      function renderPatternSelectorButtons() {
        patternButtonsList.innerHTML = '';
        parsedPatterns.forEach((p) => {
          const btn = document.createElement('button');
          const isActive = p.index === selectedPatternIndex;
          btn.className = isActive
            ? 'text-xs bg-neutral-900 border border-neutral-900 text-white px-3 py-1 rounded-full font-medium transition-colors cursor-pointer shadow-sm'
            : 'text-xs bg-white border border-neutral-200 hover:bg-neutral-100 text-neutral-700 px-3 py-1 rounded-full font-medium transition-colors cursor-pointer';
          
          btn.textContent = `${p.name} (${p.notes.length} notes)`;
          btn.addEventListener('click', () => {
            selectedPatternIndex = p.index;
            renderPatternSelectorButtons();
            renderActivePattern(p);
          });
          patternButtonsList.appendChild(btn);
        });
      }

      function renderActivePattern(p: any) {
        currentNotes = p.notes;
        selectedChannelRackIndex = -1; // Reset channel filter to All on pattern change
        
        renderChannelSelectorButtons();
        renderFilteredNotes();
      }

      function renderChannelSelectorButtons() {
        channelButtonsList.innerHTML = '';
        
        // Find unique rack channel indices in current pattern
        const rackIndices = Array.from(new Set(currentNotes.map((n) => n.rack))).sort((a, b) => a - b);
        
        if (rackIndices.length <= 1) {
          // If there's only 1 channel or none, no need for filter container
          channelSelectorContainer.classList.add('hidden');
          return;
        }
        
        channelSelectorContainer.classList.remove('hidden');

        // 1. Add "All Channels" button
        const allBtn = document.createElement('button');
        const isAllActive = selectedChannelRackIndex === -1;
        allBtn.className = isAllActive
          ? 'text-xs bg-neutral-900 border border-neutral-900 text-white px-3 py-1 rounded-full font-medium transition-colors cursor-pointer shadow-sm'
          : 'text-xs bg-white border border-neutral-200 hover:bg-neutral-100 text-neutral-700 px-3 py-1 rounded-full font-medium transition-colors cursor-pointer';
        allBtn.textContent = `All Channels (${currentNotes.length} notes)`;
        allBtn.addEventListener('click', () => {
          selectedChannelRackIndex = -1;
          renderChannelSelectorButtons();
          renderFilteredNotes();
        });
        channelButtonsList.appendChild(allBtn);

        // 2. Add button for each rack channel index
        rackIndices.forEach((rackIdx) => {
          const channel = currentChannels.find((c) => c.index === rackIdx);
          const channelName = channel ? channel.name : `Rack Item #${rackIdx}`;
          const noteCount = currentNotes.filter((n) => n.rack === rackIdx).length;
          
          const btn = document.createElement('button');
          const isActive = selectedChannelRackIndex === rackIdx;
          btn.className = isActive
            ? 'text-xs bg-neutral-900 border border-neutral-900 text-white px-3 py-1 rounded-full font-medium transition-colors cursor-pointer shadow-sm'
            : 'text-xs bg-white border border-neutral-200 hover:bg-neutral-100 text-neutral-700 px-3 py-1 rounded-full font-medium transition-colors cursor-pointer';
          
          btn.textContent = `${channelName} (${noteCount} notes)`;
          btn.addEventListener('click', () => {
            selectedChannelRackIndex = rackIdx;
            renderChannelSelectorButtons();
            renderFilteredNotes();
          });
          channelButtonsList.appendChild(btn);
        });
      }

      function renderFilteredNotes() {
        const filteredNotes = selectedChannelRackIndex === -1
          ? currentNotes
          : currentNotes.filter((n) => n.rack === selectedChannelRackIndex);

        notesCountBadge.textContent = `${filteredNotes.length} Notes`;

        pianoRollContainer.classList.remove('hidden');

        // Render piano roll
        setTimeout(() => {
          drawPianoRoll(filteredNotes, currentPPQ);
        }, 0);

        // Populate notes table list
        notesList.innerHTML = '';
        filteredNotes.slice(0, 300).forEach((note, idx) => {
          const row = document.createElement('tr');
          row.className = 'border-b border-neutral-100 hover:bg-neutral-50';
          
          const channel = currentChannels.find((c) => c.index === note.rack);
          const channelName = channel ? channel.name : `Rack Item #${note.rack}`;
          
          let sampleFilenameHtml = '<span class="text-neutral-400 italic text-[10px]">Generator</span>';
          let pureFilename = '';
          if (channel && channel.samplePath && channel.samplePath !== 'Generator (No Sample)') {
            const pathParts = channel.samplePath.split(/[\\\/]/);
            pureFilename = pathParts[pathParts.length - 1];
            sampleFilenameHtml = pureFilename;
          }
          
          const colorScheme = RACK_COLORS[note.rack % RACK_COLORS.length];
          const badgeColor = colorScheme.stroke;
          
          row.innerHTML = `
            <td class="py-2 text-neutral-500 text-xs font-mono">Note ${idx + 1}</td>
            <td class="py-2 text-neutral-800 font-semibold text-xs sm:text-sm">
              <span class="inline-flex items-center space-x-1.5">
                <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: ${badgeColor}"></span>
                <span class="truncate max-w-[100px] sm:max-w-[160px]" title="${channelName}">${channelName}</span>
              </span>
            </td>
            <td class="py-2 text-neutral-600 font-mono text-[10px] sm:text-xs truncate max-w-[120px] sm:max-w-[180px]" title="${pureFilename}">${sampleFilenameHtml}</td>
            <td class="py-2 text-neutral-600 font-mono text-xs">${note.position}</td>
            <td class="py-2 text-neutral-600 font-mono text-xs">${note.duration}</td>
            <td class="py-2 text-neutral-800 font-bold text-xs sm:text-sm">${getNoteName(note.key)}</td>
            <td class="py-2 text-neutral-600 font-mono text-xs">${note.velocity}</td>
            <td class="py-2 text-neutral-600 font-mono text-xs">${note.midiChannel}</td>
          `;
          notesList.appendChild(row);
        });

        if (filteredNotes.length > 300) {
          const row = document.createElement('tr');
          row.innerHTML = `<td colspan="7" class="py-3 text-center text-neutral-400 text-xs italic">... showing first 300 notes out of ${filteredNotes.length} total</td>`;
          notesList.appendChild(row);
        }
      }

      function stopAllChannels() {
        Object.values(activeChannelSources).forEach((src) => {
          try {
            src.stop();
          } catch (e) {}
        });
        activeChannelSources = {};

        // Reset UI buttons if they exist
        document.querySelectorAll('.btn-play-channel').forEach(btn => {
          btn.innerHTML = PLAY_SVG;
          btn.classList.remove('text-red-500');
          btn.classList.add('text-neutral-600');
        });
      }

      function stopPreview() {
        isPlaying = false;
        
        if (playAnimationId) {
          cancelAnimationFrame(playAnimationId);
          playAnimationId = null;
        }

        // Resume context in case it was suspended, so future plays work normally
        if (audioCtx && audioCtx.state === 'suspended') {
          audioCtx.resume();
        }

        // Stop all oscillators
        activeOscillators.forEach((osc) => {
          try {
            osc.stop();
          } catch (e) {}
        });
        activeOscillators = [];

        // Stop all sample sources
        activeSampleSources.forEach((src) => {
          try {
            src.stop();
          } catch (e) {}
        });
        activeSampleSources = [];

        // Reset buttons
        btnPausePreview.disabled = true;
        btnStopPreview.disabled = true;
        textPause.textContent = 'Pause';
        iconPause.innerHTML = '<path d="M5.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75A.75.75 0 007.25 3h-1.5zM12.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75a.75.75 0 00-.75-.75h-1.5z" />';

        // Redraw final state without playhead (reset to 0)
        const filteredNotes = selectedChannelRackIndex === -1
          ? currentNotes
          : currentNotes.filter((n) => n.rack === selectedChannelRackIndex);
        
        // Use timeout to ensure canvas is drawn cleanly
        setTimeout(() => {
          drawPianoRoll(filteredNotes, currentPPQ);
        }, 0);
      }

      function togglePausePreview() {
        if (!audioCtx) return;
        
        if (audioCtx.state === 'running') {
          audioCtx.suspend().then(() => {
            textPause.textContent = 'Resume';
            iconPause.innerHTML = '<path d="M6.3 2.841A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.269l9.324-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />';
          });
        } else if (audioCtx.state === 'suspended') {
          audioCtx.resume().then(() => {
            textPause.textContent = 'Pause';
            iconPause.innerHTML = '<path d="M5.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75A.75.75 0 007.25 3h-1.5zM12.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75a.75.75 0 00-.75-.75h-1.5z" />';
          });
        }
      }

      function playPreview() {
        // Stop current to start from the beginning
        stopPreview(); 

        const filteredNotes = selectedChannelRackIndex === -1
          ? currentNotes
          : currentNotes.filter((n) => n.rack === selectedChannelRackIndex);

        if (filteredNotes.length === 0) return;

        // Initialize AudioContext
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        }

        // Resume if suspended
        if (audioCtx.state === 'suspended') {
          audioCtx.resume();
        }

        isPlaying = true;
        btnPausePreview.disabled = false;
        btnStopPreview.disabled = false;
        textPause.textContent = 'Pause';
        iconPause.innerHTML = '<path d="M5.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75A.75.75 0 007.25 3h-1.5zM12.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75a.75.75 0 00-.75-.75h-1.5z" />';

        const bpmInput = document.getElementById('input-preview-bpm') as HTMLInputElement | null;
        const tempo = bpmInput ? parseFloat(bpmInput.value) || 130 : 130;
        const secondsPerTick = 60 / (tempo * currentPPQ);
        playStartTime = audioCtx.currentTime + 0.1;

        // Retrieve selected waveform
        const waveformRadio = document.querySelector('input[name="synth-waveform"]:checked') as HTMLInputElement | null;
        const waveform = waveformRadio ? waveformRadio.value as OscillatorType : 'triangle';

        // Retrieve ADSR values
        const attackInput = document.getElementById('synth-attack') as HTMLInputElement | null;
        const decayInput = document.getElementById('synth-decay') as HTMLInputElement | null;
        const sustainInput = document.getElementById('synth-sustain') as HTMLInputElement | null;
        const releaseInput = document.getElementById('synth-release') as HTMLInputElement | null;

        const attack = attackInput ? parseFloat(attackInput.value) : 0.05;
        const decay = decayInput ? parseFloat(decayInput.value) : 0.10;
        const sustain = sustainInput ? parseFloat(sustainInput.value) : 0.60;
        const release = releaseInput ? parseFloat(releaseInput.value) : 0.30;

        filteredNotes.forEach((note) => {
          const noteTime = playStartTime + note.position * secondsPerTick;
          const noteDuration = note.duration * secondsPerTick;

          const gainNode = audioCtx!.createGain();
          const maxVolume = (note.velocity / 127) * 0.12; // cap gain to avoid loudness clipping
          const sustainVolume = maxVolume * sustain;

          // Apply ADSR Envelope to gain Node
          gainNode.gain.setValueAtTime(0, noteTime);
          // Attack phase
          gainNode.gain.linearRampToValueAtTime(maxVolume, noteTime + attack);
          // Decay phase to Sustain level
          gainNode.gain.linearRampToValueAtTime(sustainVolume, noteTime + attack + decay);
          // Maintain Sustain until release phase starts
          gainNode.gain.setValueAtTime(sustainVolume, noteTime + noteDuration);
          // Release phase
          gainNode.gain.exponentialRampToValueAtTime(0.0001, noteTime + noteDuration + release);

          gainNode.connect(audioCtx!.destination);

          const sampleBuffer = sampleBuffers[note.rack];
          
          if (sampleBuffer) {
            // Play Real Audio Sample
            const source = audioCtx!.createBufferSource();
            source.buffer = sampleBuffer;
            
            // Pitch shifting: usually MIDI 60 (C5) is the root note for FL Studio samples
            // But we might want to check the channel root note if available. Defaulting to 60.
            source.playbackRate.value = Math.pow(2, (note.key - 60) / 12);
            
            source.connect(gainNode);
            source.start(noteTime);
            source.stop(noteTime + noteDuration + release);
            
            activeSampleSources.push(source);
          } else {
            // Fallback to synthetic Oscillator
            const freq = 440 * Math.pow(2, (note.key - 69) / 12);
            const osc = audioCtx!.createOscillator();
            
            osc.type = waveform;
            osc.frequency.setValueAtTime(freq, noteTime);
            osc.connect(gainNode);
            
            osc.start(noteTime);
            osc.stop(noteTime + noteDuration + release);
            
            activeOscillators.push(osc);
          }
        });

        // Start playhead animation loop
        function animatePlayhead() {
          if (!isPlaying || !audioCtx) return;
          
          const elapsed = audioCtx.currentTime - playStartTime;
          const currentTick = elapsed / secondsPerTick;

          if (currentTick >= currentMaxEnd) {
            stopPreview();
            return;
          }

          drawPianoRoll(filteredNotes, currentPPQ, currentTick);
          playAnimationId = requestAnimationFrame(animatePlayhead);
        }

        playAnimationId = requestAnimationFrame(animatePlayhead);
      }
    </script>
  </body>
</html>
